{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Launch HotelStay API + UI",
      "configurations": [
        "Launch HotelStay API",
        "Launch HotelStay UI"
      ]
    }
  ],
  "configurations": [
    {
      "name": "Launch HotelStay API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/HotelStay.Api/bin/Debug/net10.0/HotelStay.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/HotelStay.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on: https://localhost:59292"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Launch HotelStay UI",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "start-ui",
      "cwd": "${workspaceFolder}/hotelstay-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 9229,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Compiled successfully." 
      }
    }
  ]
}
